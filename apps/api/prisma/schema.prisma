generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  SHOPKEEPER
  WHOLESALER
  CUSTOMER
}

enum RecordFormat {
  LP
  TWO_LP
  THREE_LP
  TWELVE_INCH
  SEVEN_INCH
  CD
  TWO_CD
  CASSETTE
  MERCH
}

enum RecordCondition {
  M
  VGP
  VG
  GP
  G
  F
  P
}

enum StoreLocation {
  MAIN_STORE
  WAREHOUSE
  CONSIGNMENT
}

/// Kind of a sales/stock location. TEMPORARY covers pop-ups and events.
enum LocationKind {
  RETAIL
  STORAGE
  TEMPORARY
  CONSIGNMENT
}

enum PostCategory {
  STAFF_PICKS
  HIGHLIGHTS
  NEWS
  INTERVIEW
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PoStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CANCELLED
}

enum VoucherKind {
  PERCENT
  FIXED_IDR
}

enum NewsletterSource {
  STOREFRONT
  CHECKOUT
  POS
  MANUAL
  IMPORT
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
}

enum CategoryPageTemplate {
  FULL_HERO
  HALF_HERO
}

enum CategoryPageStatus {
  DRAFT
  PUBLISHED
}

enum CategoryPageKind {
  PRODUCT_PAGE
  NEWS_CATEGORY
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(CUSTOMER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  posts Post[]
}

model Post {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  excerpt     String?
  body        String
  coverUrl    String?
  category    PostCategory @default(NEWS)
  status      PostStatus   @default(DRAFT)
  publishedAt DateTime?
  author      User         @relation(fields: [authorId], references: [id])
  authorId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status, publishedAt])
  @@index([category])
}

model Release {
  id                String           @id @default(cuid())
  artist            String
  title             String
  label             String?
  catNumber         String?
  year              Int?
  format            RecordFormat
  genre             String?
  condition         RecordCondition
  priceIdr          Int
  stock             Int              @default(0)
  notes             String?
  imageUrl          String?
  gallery           Json?
  barcode           String?          @unique
  storeLocation     StoreLocation    @default(MAIN_STORE)
  shelfLocation     String?
  lowStockThreshold Int              @default(2)
  discogsId         String?          @unique
  country           String?
  compareAtIdr      Int?
  mediaGrade        RecordCondition?
  sleeveGrade       RecordCondition?
  tracks            Json?
  sizing            Json?
  channelListings   Json?
  slug              String?          @unique
  seoTitle          String?
  seoDescription    String?
  featured          Boolean          @default(false)
  preorder          Boolean          @default(false)
  preorderEta       DateTime?
  onSale            Boolean          @default(false)
  dealposProductId  String?
  dealposVariantId  String?          @unique
  costIdr           Int?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  purchaseOrderLines PurchaseOrderLine[]
  importLines        ImportOrderLine[]
  channelPrices      ReleaseChannelPrice[]
  // barcode and discogsId already have implicit indexes via @unique

  @@index([artist, title])
}

// ---------------------------------------------------------------------------
// DealPOS mirror tables — populated by the dealpos sync module, read by finance
// ---------------------------------------------------------------------------

model DpOutlet {
  id        String  @id
  name      String
  code      String?
  suspended Boolean @default(false)
}

model DpSupplier {
  id     String  @id
  name   String
  code   String?
  phone  String?
  mobile String?
  email  String?
}

model DpCustomer {
  id        String    @id
  name      String
  code      String?
  mobile    String?
  email     String?
  birthDate DateTime?
  joinDate  DateTime?
}

model DpPaymentMethod {
  id        Int     @id
  name      String
  type      String?
  suspended Boolean @default(false)
}

model DpInvoice {
  id            String             @id
  number        String             @unique
  outlet        String?
  customerName  String?
  tag           String?
  date          DateTime
  created       DateTime
  amount        Decimal            @db.Decimal(18, 2)
  gross         Decimal?           @db.Decimal(18, 2)
  discountTotal Decimal?           @db.Decimal(18, 2)
  tax           Decimal?           @db.Decimal(18, 2)
  sales         Decimal?           @db.Decimal(18, 2)
  surcharge     Decimal?           @db.Decimal(18, 2)
  paymentStatus String?
  fulfillment   String?
  isVoid        Boolean            @default(false)
  lines         DpInvoiceLine[]
  payments      DpInvoicePayment[]

  @@index([date])
  @@index([tag])
  @@index([outlet])
}

model DpInvoiceLine {
  id             String    @id @default(cuid())
  invoice        DpInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId      String
  variantId      String?
  name           String
  code           String?
  quantity       Decimal   @db.Decimal(18, 3)
  cost           Decimal?  @db.Decimal(18, 2)
  price          Decimal   @db.Decimal(18, 2)
  discountAmount Decimal?  @db.Decimal(18, 2)
  sales          Decimal?  @db.Decimal(18, 2)
  tax            Decimal?  @db.Decimal(18, 2)

  @@index([invoiceId])
  @@index([variantId])
  @@index([code])
}

model DpInvoicePayment {
  id        String    @id @default(cuid())
  invoice   DpInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String
  date      DateTime?
  amount    Decimal   @db.Decimal(18, 2)
  method    String
  code      String?
  note      String?

  @@index([invoiceId])
  @@index([method])
}

model DpBill {
  id            String       @id
  number        String
  outlet        String?
  supplierName  String?
  type          String?
  date          DateTime
  due           DateTime?
  created       DateTime?
  amount        Decimal      @db.Decimal(18, 2)
  gross         Decimal?     @db.Decimal(18, 2)
  tax           Decimal?     @db.Decimal(18, 2)
  purchase      Decimal?     @db.Decimal(18, 2)
  delivery      String?
  paymentStatus String?
  lines         DpBillLine[]

  @@index([date])
  @@index([supplierName])
}

model DpBillLine {
  id        String   @id @default(cuid())
  bill      DpBill   @relation(fields: [billId], references: [id], onDelete: Cascade)
  billId    String
  variantId String?
  name      String
  code      String?
  quantity  Decimal  @db.Decimal(18, 3)
  price     Decimal  @db.Decimal(18, 2)
  discount  Decimal? @db.Decimal(18, 2)

  @@index([billId])
  @@index([variantId])
}

model SyncState {
  entity    String    @id
  status    String    @default("idle")
  message   String?
  cursor    String?
  lastRunAt DateTime?
}

// Single-row settings for the Social Media feature (Meta catalog feed + WhatsApp)
model SocialSettings {
  id                Int      @id @default(1)
  waPhone           String?
  waTemplate        String   @default("Hi Medium Format! I'd like to buy *{title}* ({price}). Is it still available?")
  igUsername        String?
  fbPageUrl         String?
  storefrontUrlBase String?
  feedEnabled       Boolean  @default(true)
  updatedAt         DateTime @updatedAt
}

/// Local, writable registry of sales/stock locations and events (pop-ups).
/// Not part of the read-only DealPOS mirror. Physical stores may link to the
/// StoreLocation enum for item counts; TEMPORARY entries are events with a
/// date window and an optional matchKey used to attribute DealPOS sales.
model Location {
  id            String         @id @default(cuid())
  name          String
  kind          LocationKind   @default(RETAIL)
  address       String?
  active        Boolean        @default(true)
  startDate     DateTime?
  endDate       DateTime?
  shelves       String[]       @default([])
  matchKey      String?
  storeLocation StoreLocation?
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([kind])
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  poNumber     String              @unique
  supplierId   String?
  supplierName String
  status       PoStatus            @default(DRAFT)
  currency     String              @default("IDR")
  subtotalIdr  Int                 @default(0)
  taxIdr       Int                 @default(0)
  totalIdr     Int                 @default(0)
  orderedAt    DateTime?
  etaAt        DateTime?
  receivedAt   DateTime?
  notes        String?
  sourceBillId String?             @unique
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  lines        PurchaseOrderLine[]

  @@index([status, etaAt])
}

model PurchaseOrderLine {
  id              String        @id @default(cuid())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderId String
  release         Release?      @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  releaseId       String?
  description     String
  qtyOrdered      Int           @default(0)
  qtyReceived     Int           @default(0)
  unitCostIdr     Int           @default(0)
  totalIdr        Int           @default(0)

  @@index([purchaseOrderId])
  @@index([releaseId])
}

model Voucher {
  id          String      @id @default(cuid())
  code        String      @unique
  kind        VoucherKind
  value       Int
  minOrderIdr Int         @default(0)
  startsAt    DateTime?
  expiresAt   DateTime?
  usageLimit  Int?
  usageCount  Int         @default(0)
  active      Boolean     @default(true)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([active, expiresAt])
}

model NewsletterSubscriber {
  id             String           @id @default(cuid())
  email          String           @unique
  name           String?
  source         NewsletterSource @default(MANUAL)
  subscribedAt   DateTime         @default(now())
  unsubscribedAt DateTime?
  tags           String[]

  @@index([source, subscribedAt])
}

model NewsletterCampaign {
  id             String         @id @default(cuid())
  subject        String
  previewText    String?
  body           String
  status         CampaignStatus @default(DRAFT)
  scheduledAt    DateTime?
  sentAt         DateTime?
  recipientCount Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status, scheduledAt])
}

// ---------------------------------------------------------------------------
// Import-order pipeline (invoice-parsed procurement → inventory)
// ---------------------------------------------------------------------------

enum ImportOrigin {
  INTERNATIONAL
  DOMESTIC
}

enum ImportStatus {
  DRAFT
  SUBMITTED
  CONSOLIDATED
  PRICED
  RECEIVED
  INVENTORY_UPDATED
  CANCELLED
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  PAYPAL
  CASH
  OTHER
}

enum ReimbursementStatus {
  NOT_REQUIRED
  PENDING
  REIMBURSED
}

enum SalesChannel {
  SHOPEE
  TOKOPEDIA
  WEBSITE
  POS
  DISCOGS
}

enum ImportLineMatchStatus {
  MATCHED
  NEW
  AMBIGUOUS
}

enum ImportAttachmentKind {
  VENDOR_INVOICE
  FORWARDER_INVOICE
  PAYMENT_PROOF
  REIMBURSEMENT_PROOF
}

model ImportOrder {
  id                  String              @id @default(cuid())
  number              String              @unique
  vendorName          String
  origin              ImportOrigin        @default(INTERNATIONAL)
  currency            String              // ISO 4217: USD, EUR, IDR
  orderDate           DateTime
  fxRate              Decimal             @default(1) @db.Decimal(18, 6) // native -> IDR
  fxRateSource        String?
  fxRateManual        Boolean             @default(false)
  vendorShippingNative Decimal            @default(0) @db.Decimal(18, 2)
  paymentMethod       PaymentMethod       @default(BANK_TRANSFER)
  paidBy              String?
  reimbursementStatus ReimbursementStatus @default(NOT_REQUIRED)
  status              ImportStatus        @default(DRAFT)
  subtotalNative      Decimal             @default(0) @db.Decimal(18, 2)
  notes               String?
  consolidation       ImportConsolidation? @relation(fields: [consolidationId], references: [id])
  consolidationId     String?
  lines               ImportOrderLine[]
  attachments         ImportAttachment[]
  createdById         String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([status])
  @@index([orderDate])
}

model ImportOrderLine {
  id                   String                 @id @default(cuid())
  importOrder          ImportOrder            @relation(fields: [importOrderId], references: [id], onDelete: Cascade)
  importOrderId        String
  lineNo               Int
  artist               String
  title                String
  label                String?
  catNumber            String?
  barcode              String?
  formatRaw            String
  format               RecordFormat
  edition              String?
  qty                  Int
  qtyBackorder         Int                    @default(0)
  unitPriceNative      Decimal                @db.Decimal(18, 2)
  extendedNative       Decimal                @db.Decimal(18, 2)
  weightKg             Decimal                @default(0) @db.Decimal(10, 4)
  allocatedVendorShipIdr Decimal              @default(0) @db.Decimal(18, 2)
  allocatedForwarderIdr  Decimal              @default(0) @db.Decimal(18, 2)
  landedCostIdr        Decimal                @default(0) @db.Decimal(18, 2)
  discogsId            String?
  discogsRaw           Json?
  release              Release?               @relation(fields: [releaseId], references: [id])
  releaseId            String?
  matchStatus          ImportLineMatchStatus  @default(NEW)
  createdRelease       Boolean                @default(false)
  storeLocation        StoreLocation?
  shelfLocation        String?
  channelPrices        ImportLineChannelPrice[]

  @@index([importOrderId])
  @@index([barcode])
  @@index([releaseId])
}

model ImportConsolidation {
  id                 String          @id @default(cuid())
  number             String          @unique
  forwarderName      String
  forwarderInvoiceIdr Decimal        @default(0) @db.Decimal(18, 2)
  weightKgTotal      Decimal?        @db.Decimal(10, 4)
  trackingRaw        String?
  status             String          @default("open")
  orders             ImportOrder[]
  createdAt          DateTime        @default(now())
}

model ImportLineChannelPrice {
  id            String          @id @default(cuid())
  lineItem      ImportOrderLine @relation(fields: [lineItemId], references: [id], onDelete: Cascade)
  lineItemId    String
  channel       SalesChannel
  currency      String          @default("IDR")
  price         Decimal         @db.Decimal(18, 2)
  feePctApplied Decimal         @db.Decimal(6, 4)
  overridden    Boolean         @default(false)

  @@unique([lineItemId, channel])
}

model ChannelPricingConfig {
  channel  SalesChannel @id
  feePct   Decimal      @db.Decimal(6, 4) // 0.10 = 10%
  rounding String       @default("NEAREST_1000") // NEAREST_1000 | X900
  currency String       @default("IDR")
  active   Boolean      @default(true)
}

model ImportAttachment {
  id           String               @id @default(cuid())
  importOrder  ImportOrder          @relation(fields: [importOrderId], references: [id], onDelete: Cascade)
  importOrderId String
  kind         ImportAttachmentKind
  fileUrl      String
  mimeType     String?
  sizeBytes    Int?
  uploadedById String?
  uploadedAt   DateTime             @default(now())

  @@index([importOrderId])
}

model ReleaseChannelPrice {
  id        String       @id @default(cuid())
  release   Release      @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  releaseId String
  channel   SalesChannel
  currency  String       @default("IDR")
  price     Decimal      @db.Decimal(18, 2)
  updatedAt DateTime     @updatedAt

  @@unique([releaseId, channel])
}

/// Editable category / landing page: powers /pages/:slug on the storefront.
/// Two templates (FULL_HERO, HALF_HERO) render the same content in different
/// visual shapes; formatFilter drives the product grid below the hero.
model CategoryPage {
  id             String               @id @default(cuid())
  slug           String               @unique
  title          String
  formatFilter   RecordFormat?
  template       CategoryPageTemplate @default(FULL_HERO)
  kind            CategoryPageKind     @default(PRODUCT_PAGE)
  newsCategoryKey PostCategory?        @unique
  kicker         String?
  headline       String?
  salesCopy      String?
  heroImageUrl   String?
  ctaLabel       String?
  ctaHref        String?
  seoTitle       String?
  seoDescription String?
  status         CategoryPageStatus   @default(DRAFT)
  publishedAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([status, publishedAt])
  @@index([kind, status])
}
