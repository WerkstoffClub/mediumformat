DATABASE_URL="postgresql://postgres:password@localhost:5432/mediumformat"
JWT_SECRET="change-me-in-production-use-64-char-random-string"
JWT_REFRESH_SECRET="change-me-in-production-use-different-64-char-string"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# AI (OpenRouter — used for newsletter, PO packing list, etc.)
OPENROUTER_API_KEY="sk-or-..."
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Release-editor integrations — each is optional; unset ⇒ endpoint returns 501 with a friendly reason.
# Discogs personal access token (raises rate limit; anonymous still works)
# DISCOGS_TOKEN=""
# Spotify client credentials (for track / album preview search)
# SPOTIFY_CLIENT_ID=""
# SPOTIFY_CLIENT_SECRET=""
# YouTube Data API v3 key (for YouTube preview search)
# YOUTUBE_API_KEY=""
# S3 upload target for manual audio previews / re-hosted Discogs media.
# If unset, files fall back to apps/api/uploads/ served at /uploads/*.
# AWS_S3_BUCKET=""
# AWS_S3_REGION=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# iTunes (Apple) and Bandcamp integrations require no auth.
