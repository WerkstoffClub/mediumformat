# Medium Format - environment variables
# Copy to .env.local for development, or .env on the VPS.

# --- Core ---
NODE_ENV=development
APP_URL=http://localhost:8000
PUBLIC_APP_URL=http://localhost:8000

# --- Database ---
DATABASE_URL=postgresql://mediumformat:mediumformat@localhost:5432/mediumformat?schema=public

# --- Redis (BullMQ + caching) ---
REDIS_URL=redis://localhost:6379

# --- Auth.js ---
AUTH_SECRET=replace-me-with-openssl-rand-base64-32
AUTH_URL=http://localhost:8000

# --- Seed (used by prisma/seed.ts on first run) ---
SEED_ADMIN_EMAIL=admin@mediumformat.info
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Medium Format Admin
SEED_DEFAULT_LOCATION_NAME=Toko Medium Format

# --- Discogs ---
# Personal Access Token from https://www.discogs.com/settings/developers
DISCOGS_PAT=
DISCOGS_USERNAME=
DISCOGS_USER_AGENT=MediumFormatAdmin/0.1 +https://mediumformat.info
DISCOGS_MARKETPLACE_CURRENCY=IDR

# --- Xendit ---
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=
XENDIT_CALLBACK_URL=https://mediumformat.info/api/webhooks/xendit

# --- Biteship ---
BITESHIP_API_KEY=
BITESHIP_WEBHOOK_TOKEN=

# --- iTunes / Apple Music ---
# No key required for Search API.

# --- YouTube Data API v3 ---
YOUTUBE_API_KEY=

# --- OpenRouter (AI assist for newsletter, blurbs, translation) ---
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4-6
OPENROUTER_BULK_MODEL=openai/gpt-4o-mini

# --- Listmonk (newsletter / campaigns) ---
LISTMONK_BASE_URL=http://localhost:9000
LISTMONK_USERNAME=admin
LISTMONK_PASSWORD=

# --- Tokopedia (MVP-3) ---
TOKOPEDIA_FS_ID=
TOKOPEDIA_CLIENT_ID=
TOKOPEDIA_CLIENT_SECRET=
TOKOPEDIA_SHOP_ID=

# --- Shopee (MVP-4) ---
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=

# --- File uploads ---
UPLOAD_DIR=./public/uploads
MAX_UPLOAD_MB=10

# --- Google OAuth (customer sign-in) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://<your-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Staff Google sign-in (allow-list) ---
# Comma-separated emails granted ADMIN when they sign in with Google.
ADMIN_GOOGLE_EMAILS=

# --- SMTP (transactional email: password reset) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Medium Format <no-reply@mediumformat.info>
