# Copy to deploy/docker/stack.env and fill in. stack.env is gitignored (SSH details).
# Used by deploy/docker/sync.sh to push the site to the VPS stack folder.

# SSH connection to the VPS hosting Portainer/Docker
SSH_HOST=vps.lacak.live      # or the VPS IP address
SSH_USER=deploy              # ssh user that can write to STACK_DIR
SSH_PORT=22

# Folder on the VPS the Portainer stack bind-mounts from.
# Must match the paths in docker-compose.yml. Change it in BOTH places if you move it.
STACK_DIR=/opt/stacks/mediumformat
