# Copy to deploy/deploy.env and fill in. deploy.env is gitignored (secrets).
# Used by deploy/deploy.sh

# SSH connection to the VPS
SSH_HOST=vps.lacak.live      # or the VPS IP address
SSH_USER=deploy              # ssh user with write access to the web root
SSH_PORT=22

# Remote web root that nginx serves (matches root in the nginx conf)
REMOTE_ROOT=/var/www/mediumformat.info
