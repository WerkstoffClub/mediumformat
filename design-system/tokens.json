{
  "$description": "Medium Format design tokens. W3C Design Tokens (DTCG) format — $type/$value with $description. Import-ready for OpenDesign, Penpot, Tokens Studio (Figma), Style Dictionary and other design tools. Monochrome (black & white), dark-first. v2.1",
  "color": {
    "$type": "color",
    "brand": {
      "black": { "$value": "#000000", "$description": "Brand black. Logo on light, primary action on the light theme." },
      "white": { "$value": "#FFFFFF", "$description": "Brand white. Logo on dark, primary action on the dark theme." }
    },
    "surface": {
      "canvas":   { "$value": "#0F0F0F", "$description": "App / page background (dark theme)." },
      "base":     { "$value": "#0E0E0E", "$description": "Cards, sidebar, panels, modals." },
      "raised":   { "$value": "#1A1A1A", "$description": "Inputs, hovered rows, chips." },
      "hairline": { "$value": "#2A2A2A", "$description": "Borders, dividers." }
    },
    "text": {
      "ink":       { "$value": "#FFFFFF", "$description": "Headings, primary text (dark theme)." },
      "body":      { "$value": "#B4B4B4", "$description": "Body / secondary text (dark theme)." },
      "mute":      { "$value": "#6E6E6E", "$description": "Placeholders, metadata (dark theme)." },
      "on-accent": { "$value": "#000000", "$description": "Text / icons on a white surface." }
    },
    "light": {
      "canvas":   { "$value": "#F0F0F0", "$description": "Light theme background." },
      "base":     { "$value": "#FFFFFF", "$description": "Cards / panels on light." },
      "raised":   { "$value": "#F5F5F5", "$description": "Inputs, hovered rows on light." },
      "hairline": { "$value": "#E4E4E4", "$description": "Borders on light." },
      "ink":      { "$value": "#000000", "$description": "Primary text on light." },
      "body":     { "$value": "#525252", "$description": "Body text on light." }
    },
    "status": {
      "success":      { "$value": "#22C55E", "$description": "In stock, Delivered, Completed, Paid." },
      "success-tint": { "$value": "#22C55E1F", "$description": "12% tint for success badge background." },
      "info":         { "$value": "#3B82F6", "$description": "Processing, Packed, Synced." },
      "info-tint":    { "$value": "#3B82F61F", "$description": "12% tint for info badge background." },
      "warning":      { "$value": "#F59E0B", "$description": "Pending, Low stock, Reimbursement due." },
      "warning-tint": { "$value": "#F59E0B1F", "$description": "12% tint for warning badge background." },
      "danger":       { "$value": "#EF4444", "$description": "Cancelled, Refunded, Out of stock, Disputed." },
      "danger-tint":  { "$value": "#EF44441F", "$description": "12% tint for danger badge background." }
    },
    "channel": {
      "$description": "Channel colour key (v2.1). The one sanctioned exception to monochrome discipline: a per-channel hue on the CHANNEL indicator only (coloured dot + text on a neutral pill), to make multi-channel lists scannable. Never use these for status.",
      "website":   { "$value": "#6366F1", "$description": "Website / storefront." },
      "pos":       { "$value": "#0EA5E9", "$description": "In-store POS." },
      "tokopedia": { "$value": "#22C55E", "$description": "Tokopedia marketplace." },
      "shopee":    { "$value": "#F97316", "$description": "Shopee marketplace." },
      "discogs":   { "$value": "#9CA3AF", "$description": "Discogs marketplace." },
      "bandcamp":  { "$value": "#14B8A6", "$description": "Bandcamp." },
      "ebay":      { "$value": "#EAB308", "$description": "eBay." },
      "event":     { "$value": "#EC4899", "$description": "Events / pop-ups." }
    }
  },
  "space": {
    "$type": "dimension",
    "xxs": { "$value": "4px" },
    "xs":  { "$value": "8px" },
    "sm":  { "$value": "12px" },
    "md":  { "$value": "16px", "$description": "Default card padding, form rows." },
    "lg":  { "$value": "20px" },
    "xl":  { "$value": "24px", "$description": "Page padding, block spacing." },
    "2xl": { "$value": "32px", "$description": "Section gutters." },
    "3xl": { "$value": "40px" },
    "4xl": { "$value": "48px" },
    "5xl": { "$value": "64px" }
  },
  "radius": {
    "$type": "dimension",
    "sm":   { "$value": "4px",   "$description": "Checkboxes, small tags." },
    "md":   { "$value": "6px",   "$description": "Buttons, inputs — default interactive radius." },
    "lg":   { "$value": "8px",   "$description": "Cards, album covers, panels." },
    "xl":   { "$value": "12px",  "$description": "Modals, large surfaces." },
    "pill": { "$value": "999px", "$description": "Filter chips, status badges, theme toggle." },
    "full": { "$value": "9999px","$description": "Avatars, circular icon containers." }
  },
  "fontFamily": {
    "$type": "fontFamily",
    "sans": { "$value": ["Geist", "Helvetica Neue", "Arial", "sans-serif"], "$description": "All interface text. Geist (Google Fonts)." },
    "mono": { "$value": ["Geist Mono", "SF Mono", "ui-monospace", "monospace"], "$description": "Prices, catalogue numbers, barcodes." }
  },
  "fontWeight": {
    "$type": "fontWeight",
    "regular":  { "$value": 400 },
    "medium":   { "$value": 500 },
    "semibold": { "$value": 600 }
  },
  "typography": {
    "$type": "typography",
    "display-xl":  { "$value": { "fontFamily": "{fontFamily.sans}", "fontWeight": "{fontWeight.semibold}", "fontSize": "40px", "lineHeight": "48px", "letterSpacing": "-0.06em" }, "$description": "Storefront hero, marketing headlines." },
    "display-lg":  { "$value": { "fontFamily": "{fontFamily.sans}", "fontWeight": "{fontWeight.semibold}", "fontSize": "32px", "lineHeight": "40px", "letterSpacing": "-0.06em" }, "$description": "Page hero, campaign titles." },
    "h1":          { "$value": { "fontFamily": "{fontFamily.sans}", "fontWeight": "{fontWeight.semibold}", "fontSize": "24px", "lineHeight": "32px", "letterSpacing": "-0.04em" }, "$description": "Page titles." },
    "h2":          { "$value": { "fontFamily": "{fontFamily.sans}", "fontWeight": "{fontWeight.semibold}", "fontSize": "20px", "lineHeight": "28px", "letterSpacing": "-0.04em" }, "$description": "Section headings, modal titles." },
    "h3":          { "$value": { "fontFamily": "{fontFamily.sans}", "fontWeight": "{fontWeight.semibold}", "fontSize": "16px", "lineHeight": "24px", "letterSpacing": "-0.02em" }, "$description": "Sub-headings, release title on cards." },
    "body-lg":     { "$value": { "fontFamily": "{fontFamily.sans}", "fontWeight": "{fontWeight.regular}", "fontSize": "16px", "lineHeight": "24px", "letterSpacing": "0" }, "$description": "Lead paragraphs, editorial body." },
    "body":        { "$value": { "fontFamily": "{fontFamily.sans}", "fontWeight": "{fontWeight.regular}", "fontSize": "14px", "lineHeight": "20px", "letterSpacing": "0" }, "$description": "Default UI text." },
    "body-medium": { "$value": { "fontFamily": "{fontFamily.sans}", "fontWeight": "{fontWeight.medium}", "fontSize": "14px", "lineHeight": "20px", "letterSpacing": "0" }, "$description": "Emphasis, button labels." },
    "small":       { "$value": { "fontFamily": "{fontFamily.sans}", "fontWeight": "{fontWeight.regular}", "fontSize": "13px", "lineHeight": "18px", "letterSpacing": "0" }, "$description": "Captions, secondary metadata." },
    "label":       { "$value": { "fontFamily": "{fontFamily.sans}", "fontWeight": "{fontWeight.medium}", "fontSize": "12px", "lineHeight": "16px", "letterSpacing": "0.04em", "textCase": "uppercase" }, "$description": "Field labels, table headers, badges." },
    "mono-price":  { "$value": { "fontFamily": "{fontFamily.mono}", "fontWeight": "{fontWeight.medium}", "fontSize": "14px", "lineHeight": "20px", "letterSpacing": "0" }, "$description": "IDR price (USD secondary, in small mute)." },
    "mono-meta":   { "$value": { "fontFamily": "{fontFamily.mono}", "fontWeight": "{fontWeight.regular}", "fontSize": "12px", "lineHeight": "16px", "letterSpacing": "0" }, "$description": "Catalogue no., SKU, barcode, order ID." }
  },
  "shadow": {
    "$type": "shadow",
    "level-1": { "$value": { "color": "#00000080", "offsetX": "0px", "offsetY": "1px", "blur": "2px",  "spread": "0px" }, "$description": "Dropdowns, popovers, tooltips." },
    "level-2": { "$value": { "color": "#00000099", "offsetX": "0px", "offsetY": "4px", "blur": "12px", "spread": "0px" }, "$description": "Now Playing bar, sticky bars." },
    "level-3": { "$value": { "color": "#000000B3", "offsetX": "0px", "offsetY": "8px", "blur": "24px", "spread": "0px" }, "$description": "Modals, command palette." }
  }
}
